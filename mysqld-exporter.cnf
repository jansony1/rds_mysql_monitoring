[client]
# RDS MySQL 连接信息 - 请替换为实际值
host=database-1.cs8ucd81mg2k.us-east-1.rds.amazonaws.com
port=3306
user=exporter
# 密码优先使用环境变量 MYSQLD_EXPORTER_PASSWORD (更安全)
# 如果设置了环境变量, 下面这行会被覆盖
password=YOUR_EXPORTER_PASSWORD

# SSL/TLS 连接到 RDS (推荐)
# 证书下载: https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
ssl-ca=/etc/ssl/certs/global-bundle.pem
ssl-mode=VERIFY_IDENTITY
